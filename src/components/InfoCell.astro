---
interface Props {
  cellTitle: string;
  cellText: string;
  accent?: boolean;
}

const { cellTitle, cellText, accent = false } = Astro.props;
---

<div
  class="flex flex-col gap-2 py-3.5 px-5 border-r border-white-muted first:pl-0"
>
  <p class="font-mono text-xs text-neutral-content tracking-widest-2 uppercase">
    {cellTitle}
  </p>
  <p
    class={`font-display text-sm font-extrabold tracking-normal uppercase ${accent ? 'text-primary' : ''}`}
  >
    {cellText}
  </p>
</div>
